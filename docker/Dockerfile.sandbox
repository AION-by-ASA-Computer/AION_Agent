# syntax=docker/dockerfile:1.6
# Per-session sandbox MCP worker (Podman/Docker sidecar)
# Build: docker build -f docker/Dockerfile.sandbox -t aion/sandbox .

ARG PYTHON_VERSION=3.13-slim@sha256:eb43ff125d8d58d7449dcba7d336c23bcac412f526d861db493b9994d8010280
ARG UV_VERSION=latest@sha256:3d868e555f8f1dbc324afa005066cd11e1053fc4743b9808ca8025283e65efa5

FROM ghcr.io/astral-sh/uv:${UV_VERSION} AS uv-bin

FROM python:${PYTHON_VERSION} AS builder

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    UV_LINK_MODE=copy \
    UV_COMPILE_BYTECODE=1 \
    UV_PYTHON_DOWNLOADS=never \
    UV_CACHE_DIR=/tmp/uv-cache

COPY --from=uv-bin /uv /uvx /usr/local/bin/

RUN uv venv /opt/venv
ENV VIRTUAL_ENV=/opt/venv \
    PATH="/opt/venv/bin:$PATH"

WORKDIR /build
COPY requirements-sandbox.txt requirements-sandbox-skills.txt ./
RUN --mount=type=cache,target=/tmp/uv-cache \
    uv pip install --python /opt/venv/bin/python -r requirements-sandbox.txt

FROM python:${PYTHON_VERSION} AS runtime

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    VIRTUAL_ENV=/opt/venv \
    PATH="/opt/venv/bin:$PATH" \
    AION_DATA_DIR=/session \
    AION_SANDBOX_IN_CONTAINER=1 \
    AION_SANDBOX_FLAT_SESSION_ROOT=1

RUN apt-get update \
 && apt-get install -y --no-install-recommends tini nodejs npm poppler-utils \
 && rm -rf /var/lib/apt/lists/* \
 && groupadd --gid 10001 sandbox \
 && useradd --uid 10001 --gid sandbox --create-home --shell /usr/sbin/nologin sandbox

COPY --from=builder /opt/venv /opt/venv

WORKDIR /app
COPY src/ ./src/
COPY mcp_servers_std/session_sandbox/ ./mcp_servers/session_sandbox/
COPY config_std/fs_policy.example.yaml ./config_std/fs_policy.example.yaml
COPY requirements-sandbox-skills.txt ./requirements-sandbox-skills.txt

RUN mkdir -p /session && chown sandbox:sandbox /session /app

USER sandbox

ENTRYPOINT ["/usr/bin/tini", "--", "python", "-u", "mcp_servers/session_sandbox/server.py"]
