# syntax=docker/dockerfile:1.6
# website (Docusaurus 3.10) — static build served via nginx
# Build context: repository root
#   docker build -f docker/Dockerfile.website \
#     --build-arg DOCUSAURUS_BASE_URL=/docs/ -t aion/website .
#
# Versione Node allineata alla shell di dev (node v22.22.0). Node 22 e' LTS.
# `website/pnpm-lock.yaml` e' gitignored -> su fresh clone non c'e' lockfile,
# quindi usiamo `pnpm install` (no `--frozen-lockfile`).
ARG NODE_VERSION=22-alpine@sha256:16e22a550f3863206a3f701448c45f7912c6896a62de43add43bb9c86130c3e2
ARG PNPM_VERSION=10.30.1
ARG NGINX_VERSION=alpine@sha256:54f2a904c251d5a34adf545a72d32515a15e08418dae0266e23be2e18c66fefa

# ---------- builder ----------
FROM node:${NODE_VERSION} AS builder

ARG PNPM_VERSION
ARG DOCUSAURUS_BASE_URL=/docs/
ENV DOCUSAURUS_BASE_URL=$DOCUSAURUS_BASE_URL

RUN corepack enable && corepack prepare pnpm@${PNPM_VERSION} --activate

WORKDIR /repo

# Docusaurus config reads ../docs at build time (see website/docusaurus.config.ts)
COPY website/package.json ./website/
# Lockfile opzionale: glob tollerante (no errore se manca)
COPY website/pnpm-lock.yam[l] ./website/
RUN cd website && pnpm install --prefer-offline

COPY website/ ./website/
COPY docs/    ./docs/

# baseUrl deve essere /docs/ (path pubblico dietro Caddy). La ARG vuota da compose
# viene espansa bash-style qui così da non finire mai su "/".
RUN cd website && DOCUSAURUS_BASE_URL="${DOCUSAURUS_BASE_URL:-/docs/}" && [ "$DOCUSAURUS_BASE_URL" = "/" ] && DOCUSAURUS_BASE_URL="/docs/" || true && DOCUSAURUS_BASE_URL="$DOCUSAURUS_BASE_URL" pnpm run build

# ---------- runner ----------
FROM nginx:${NGINX_VERSION} AS runner

COPY docker/nginx-website.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /repo/website/build /usr/share/nginx/html

EXPOSE 3000
